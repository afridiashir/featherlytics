generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

/// A user's connected Google Analytics account + selected GA4 property.
model GaConnection {
  id           String   @id @default(cuid())
  userId       String   @unique // Clerk user id
  refreshToken String
  propertyId   String?
  propertyName String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

/// A saved conversion funnel: a custom name + an ordered list of event steps.
model Funnel {
  id        String   @id @default(cuid())
  userId    String // Clerk user id
  name      String
  steps     String[] // ordered event names
  labels    String[] // custom display name per step (same order as steps)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}
